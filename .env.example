# Database — used by both Nuxt (runtime) and Drizzle Kit (migrations)
NUXT_DB_URL=mysql://user:password@localhost:3306/dashboard

# Firebase Admin SDK — server-side only (never exposed to browser)
NUXT_FIREBASE_PROJECT_ID=your-project-id
NUXT_FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
NUXT_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Firebase Auth SDK — browser-visible (NUXT_PUBLIC_ prefix required)
NUXT_PUBLIC_FIREBASE_API_KEY=AIza...
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NUXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
